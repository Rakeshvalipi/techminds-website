{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/not-found.js"
    ],
    "/(main)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(main)/layout.css",
      "static/chunks/app/(main)/layout.js"
    ],
    "/(main)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(main)/page.css",
      "static/chunks/app/(main)/page.js"
    ],
    "/manifest.webmanifest/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/manifest.webmanifest/route.js"
    ],
    "/(main)/about/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(main)/about/page.css",
      "static/chunks/app/(main)/about/page.js"
    ],
    "/(main)/contact/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(main)/contact/page.js"
    ],
    "/(main)/services/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(main)/services/page.js"
    ],
    "/(main)/services/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(main)/services/[slug]/page.js"
    ]
  }
}